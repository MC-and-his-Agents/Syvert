{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "safe_to_merge",
    "summary",
    "findings",
    "required_actions"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REQUEST_CHANGES"
      ]
    },
    "safe_to_merge": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "required_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "details",
          "code_location"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "string",
            "minLength": 1
          },
          "code_location": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "absolute_file_path",
              "line_range"
            ],
            "properties": {
              "absolute_file_path": {
                "type": "string",
                "minLength": 1
              },
              "line_range": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "start",
                  "end"
                ],
                "properties": {
                  "start": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "end": {
                    "type": "integer",
                    "minimum": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
